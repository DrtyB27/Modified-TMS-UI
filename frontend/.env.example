# Base URL the frontend uses to reach the read-only proxy.
#
# Local dev (Vite proxies /api -> Flask): leave unset, defaults to /api.
# Cloudflare, Worker on same domain route (recommended, keeps it same-origin):
#   VITE_API_BASE=/api
# Cloudflare, Worker on its own workers.dev/subdomain (uses CORS):
#   VITE_API_BASE=https://dlx-tms-sandbox-wireframe.<account>.workers.dev/api
VITE_API_BASE=/api
